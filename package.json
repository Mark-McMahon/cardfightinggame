{
  "name": "auto-battler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev:server": "pnpm --filter @cardgame/server dev",
    "dev:client": "pnpm --filter @cardgame/client dev",
    "build:client": "pnpm --filter @cardgame/client build",
    "sim:micro": "pnpm --filter @cardgame/sim micro",
    "sim:macro": "pnpm --filter @cardgame/sim macro",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msgpackr-extract"]
  }
}
